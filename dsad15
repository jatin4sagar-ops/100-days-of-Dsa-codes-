#include <stdio.h>

int main() {
    int m, n;

    // Read rows and columns
    scanf("%d %d", &m, &n);

    int matrix[m][n];
    int sum = 0;

    // Read matrix and calculate diagonal sum
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);

            // Check primary diagonal
            if (i == j) {
                sum += matrix[i][j];
            }
        }
    }

    // Print result
    printf("%d", sum);

    return 0;
}