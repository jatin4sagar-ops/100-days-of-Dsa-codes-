int maxSubArray(int* nums, int numsSize) {
    int maxSum = nums[0];
    int currentSum = nums[0];

    for (int i = 1; i < numsSize; i++) {

        // Decide whether to extend subarray or start new
        if (currentSum < 0)
            currentSum = nums[i];
        else
            currentSum += nums[i];

        // Update maximum sum
        if (currentSum > maxSum)
            maxSum = currentSum;
    }

    return maxSum;
}