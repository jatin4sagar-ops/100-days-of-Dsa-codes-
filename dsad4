# Read input
n = int(input("Enter number of elements: "))
arr = list(map(int, input("Enter elements: ").split()))

# Two-pointer approach
left = 0
right = n - 1

while left < right:
    # Swap elements
    arr[left], arr[right] = arr[right], arr[left]
    
    # Move pointers
    left += 1
    right -= 1

# Print reversed array
print("Reversed array:")
print(*arr)